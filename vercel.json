{
  "version": 2,
  "buildCommand": "npm --prefix client install && npm --prefix client run build",
  "outputDirectory": "client/dist",
  "rewrites": [
    { "source": "/api/health", "destination": "/api/health.mjs" },
    { "source": "/api/generate", "destination": "/api/generate.mjs" },
    { "source": "/api/generations", "destination": "/api/generations.mjs" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
