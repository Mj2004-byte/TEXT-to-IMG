{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/**/*.mjs",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/health", "dest": "/api/health.mjs" },
    { "src": "/api/generate", "dest": "/api/generate.mjs" },
    { "src": "/api/generations", "dest": "/api/generations.mjs" },
    { "src": "/(.*)", "dest": "/client/dist/$1" }
  ]
}
